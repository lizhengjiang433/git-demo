		];

		display-timings {
			native-mode = <&timing0>;
			timing0: timing0 {
				clock-frequency = <148500000>;
				hback-porch = <148>;
				hactive = <1920>;
				hfront-porch = <88>;
				hsync-len = <44>;
				vback-porch = <36>;
				vactive = <1080>;
				vfront-porch = <4>;
				vsync-len = <5>;
			};
		};

		port {
			dsi_panel_in: endpoint {
				remote-endpoint = <&dsi0_panel_out>;
			};
		};
	};

	ports {
		port@1 {
			dsi0_panel_out: endpoint@0 {
				remote-endpoint = <&dsi_panel_in>;
			};
		};
	};
};

&dsi0combophy {
	status = "okay";
};
#endif