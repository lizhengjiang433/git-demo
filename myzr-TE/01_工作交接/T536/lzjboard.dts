&ve {
	ve-supply = <&reg_dcdc2>;
	status = "okay";
};

&gmac0_phy0 {
	reg = <0x0>;
	reset-gpios = <&pio PA 3 GPIO_ACTIVE_LOW>;
	/* For RTL8211F: PHY datasheet rst time */
	reset-assert-us = <20000>;
	reset-deassert-us = <20000>;
};

&gmac0 {
	phy-mode = "rgmii";
	pinctrl-names = "default", "sleep";
	pinctrl-0 = <&gmac0_pins_default>;
	pinctrl-1 = <&gmac0_pins_sleep>;

	// tx-delay = <10>;
	// rx-delay = <1>;

	status = "okay";

	/delete-property/ aw,rgmii-clk-ext;
};

&gmac1_phy0 {
	reg = <0x1>;
	reset-gpios = <&pio PA 4 GPIO_ACTIVE_LOW>;
	/* For RTL8211F: PHY datasheet rst time */
	reset-assert-us = <20000>;
	reset-deassert-us = <20000>;
};

&gmac1 {
	phy-mode = "rgmii";
	pinctrl-names = "default", "sleep";
	pinctrl-0 = <&gmac1_pins_default>;
	pinctrl-1 = <&gmac1_pins_sleep>;

	// tx-delay = <10>;
	// rx-delay = <3>;

	status = "okay";

	/delete-property/ aw,rgmii-clk-ext;
};

&rtp {
